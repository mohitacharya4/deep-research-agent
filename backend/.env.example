# ---- LLM provider ----------------------------------------------------------
# Which backend to use: "ollama" (local, default) or "anthropic" (cloud).
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama).
# NOTE: pick a model that supports tool calling, e.g. qwen2.5:7b-instruct or llama3.1:8b.
#       Tiny models like gemma3:270m CANNOT do reliable tool calls.
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic settings (used when LLM_PROVIDER=anthropic). Requires the "anthropic" extra.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Optional separate model for the eval judge (falls back to the main LLM if unset).
JUDGE_PROVIDER=
JUDGE_MODEL=

# ---- Tools -----------------------------------------------------------------
# Get a free key at https://app.tavily.com
TAVILY_API_KEY=

# ---- Agent behaviour -------------------------------------------------------
MAX_ITERATIONS=3
SEARCH_RESULTS_PER_QUERY=5
FETCH_TOP_N=3
LLM_TEMPERATURE=0

# ---- Server ----------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# ---- Observability ---------------------------------------------------------
# Persist every run's events (plan/search/fetch/reflect/...) + final report to a
# JSONL file under TRACE_DIR. One file per run; inspect with any JSON tool.
PERSIST_TRACES=true
TRACE_DIR=runs

# Optional LangSmith tracing for a full per-LLM-call / per-graph-step trace UI.
# Set LANGSMITH_TRACING=true and paste a key from https://smith.langchain.com.
# Off by default — the JSONL traces above work with no external account.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep-research-agent
